# Estos valores NO se configuran en un archivo .env para producción.
# Se usan como referencia; en producción se configuran como secretos/params de Firebase:
#
#   firebase functions:secrets:set SMTP_USER
#   firebase functions:secrets:set SMTP_PASS
#
# Y como parámetros normales (no secretos) si necesitas cambiarlos del valor por defecto:
#   firebase functions:config:set  -- (ya no se usa en 2nd gen; ver README de functions)
#
# Valores de referencia si usas Gmail con una "contraseña de aplicación":
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_correo_institucional@hospital.org
SMTP_PASS=contraseña_de_aplicacion_de_16_caracteres
ALERTS_FROM_NAME=Pulso CMMS Biomédico
